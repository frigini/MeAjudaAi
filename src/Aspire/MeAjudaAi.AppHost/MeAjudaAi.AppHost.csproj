<Project Sdk="Aspire.AppHost.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <UserSecretsId>6a599a9f-ccdf-4f96-b355-3aeec60dd18b</UserSecretsId>
    <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
    <!-- Desabilita o modo de bloqueio de pacotes devido às dependências específicas de plataforma do Aspire.Dashboard.Sdk -->
    <RestoreLockedMode>false</RestoreLockedMode>
  </PropertyGroup>

  <ItemGroup>
    <!-- Aspire.Hosting.AppHost: sobrescreve versão do SDK para 13.4.6 -->
