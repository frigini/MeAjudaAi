// Configure estas variáveis com os valores do seu ambiente local
// RECOMENDADO: Use o ambiente compartilhado em src/Shared/API.Collections/environments/Local.bru
vars {
  // API base URLs (Herdas do ambiente compartilhado se selecionado)
  baseUrl: http://localhost:5000
  keycloakUrl: http://localhost:8080
  // Keycloak configuration
  realm: meajudaai-realm
  clientId: meajudaai-client
  
  // O accessToken será preenchido automaticamente ao rodar o setup do Shared
  accessToken: 
  
  // Admin credentials
  adminUser: admin
  adminPassword: 
  
  // Entity IDs (populated during test execution)
  providerId: 
  userId: 
  // Test data for provider creation
  testName: João Silva
  testCity: São Paulo
  testState: SP
  testType: 1  // e.g., 1 = Individual, 2 = Company
  testVerificationStatus: 2  // e.g., 1 = Pending, 2 = Verified
}