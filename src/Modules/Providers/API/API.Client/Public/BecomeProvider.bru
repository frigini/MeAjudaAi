  token: {{accessToken}}
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "name": "João Silva Provider",
    "type": 1,
    "documentNumber": "12345678901",
    "phoneNumber": "(11) 99999-9999"
